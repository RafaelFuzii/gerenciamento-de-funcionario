generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role

  @@map("users")
}

model Funcionario {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  cpf       String   @unique
  createdAt DateTime @default(now())

  @@map("funcionarios")
}

enum Role {
  USER
  ADMIN
}
